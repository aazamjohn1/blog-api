{
	"version": 2,
	"builds": [
		{
			"src": "src/index.ts",
			"use": "@vercel/node"
		}
	],
	"routes": [
		{
			"src": "/(.*)",
			"dest": "/src/index.ts"
		}
	],
	"headers": [
		{
			"source": "/api/:path*",
			"headers": [
				{
					"key": "Access-Control-Allow-Origin",
					"value": "https://www.azamjonov.com"
				},
				{ "key": "Access-Control-Allow-Credentials", "value": "true" }
			]
		}
	]
}
